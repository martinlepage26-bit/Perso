---
import { heroFacts, siteMeta } from '../data/site';
import BackgroundTreatment from './BackgroundTreatment.astro';
---

<section class="relative overflow-hidden border-b border-white/8">
  <BackgroundTreatment variant="hero" />
  <div class="section-shell relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
    <div class="max-w-4xl rounded-[1.55rem] border border-[rgba(201,149,47,0.18)] bg-[linear-gradient(180deg,rgba(17,34,70,0.84),rgba(8,17,32,0.76))] p-6 shadow-[0_24px_48px_rgba(5,3,10,0.24)] backdrop-blur-md md:p-7">
      <p class="eyebrow">Scholarship, strategy, and systems</p>
      <h1 class="mt-5 max-w-3xl">
        Governance, scholarship, and writing in one practice.
      </h1>
      <p class="mt-5 max-w-2xl text-[1.05rem] leading-8 text-slate-100">
        Montreal-based scholar, writer, and AI governance strategist working across governance, digital culture,
        ritual studies, and public writing.
      </p>
      <p class="mt-4 max-w-2xl text-base text-slate-300">
        This site keeps publications, governance work, essays, and book projects in one clear archive.
      </p>
      <div class="mt-8">
        <a class="button-primary" href="/projects/">Explore projects</a>
      </div>
      <ul class="bullet-links mt-5">
        <li><a class="link-inline" href="/resume/">View resume</a></li>
        <li><a class="link-inline" href="/papers/">Read publications</a></li>
      </ul>
      <ul class="bullet-facts mt-8">
        {heroFacts.map((fact) => (
          <li>{fact}</li>
        ))}
      </ul>
    </div>

    <aside class="veil-panel space-y-4">
      <div>
        <p class="eyebrow">At a glance</p>
        <h2 class="mt-4 text-[1.35rem] md:text-[1.55rem]">A streamlined public profile.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Research, governance, and editorial work gathered into one legible public surface.
        </p>
      </div>

      <ul class="bullet-links">
        <li><strong>Focus:</strong> AI governance strategy, documentation, traceability, and reviewable systems.</li>
        <li><strong>Parallel work:</strong> Scholarship and writing on legitimacy, media, ritual, and symbolic systems.</li>
        <li><strong>Base:</strong> {siteMeta.location}</li>
        <li><strong>Outputs:</strong> Publications, projects, essays, and dossiers.</li>
      </ul>
    </aside>
  </div>
</section>
