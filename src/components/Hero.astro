---
import { heroFacts, siteMeta } from '../data/site';
import BackgroundTreatment from './BackgroundTreatment.astro';
---

<section class="relative overflow-hidden border-b border-white/8">
  <BackgroundTreatment variant="hero" />
  <div class="section-shell relative grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_28rem] lg:items-end">
    <div class="max-w-4xl rounded-[2.1rem] border border-[rgba(201,168,76,0.16)] bg-[linear-gradient(180deg,rgba(11,31,46,0.72),rgba(15,59,62,0.2))] p-7 shadow-[0_30px_100px_rgba(0,0,0,0.24)] backdrop-blur-md md:p-8">
      <p class="eyebrow">Scholarship, strategy, and symbolic systems</p>
      <h1 class="mt-5 max-w-4xl text-3xl leading-none md:text-5xl">
        Martin Lepage builds serious public work at the threshold of governance and culture.
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-100">
        Montreal-based scholar, writer, and AI governance consultant working across AI governance, digital culture,
        ritual and media analysis, queer theory, and experimental authorship.
      </p>
      <p class="mt-6 max-w-3xl text-base text-slate-200">
        The site is designed to hold academic publications, consulting direction, independent projects, and long-form
        writing in one place without forcing them into separate identities. The governing tone is precise, inspectable,
        and human, but the visual language now leans toward an observatory: horizon-facing, luminous, and calm under
        scrutiny.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href="/projects/">Explore projects</a>
        <a class="button-secondary" href="/resume/">Download CV</a>
        <a class="button-secondary" href="/papers/">Read publications</a>
      </div>
      <ul class="mt-10 flex flex-wrap gap-3">
        {heroFacts.map((fact) => (
          <li class="rounded-full border border-white/12 bg-[rgba(255,255,255,0.08)] px-4 py-2 text-sm text-slate-100 backdrop-blur-md shadow-[inset_0_1px_0_rgba(255,255,255,0.12)]">
            {fact}
          </li>
        ))}
      </ul>
    </div>

    <aside class="veil-panel relative overflow-hidden p-0">
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.02)),radial-gradient(circle_at_52%_18%,rgba(201,168,76,0.18),transparent_34%),linear-gradient(180deg,rgba(61,214,200,0.14),rgba(11,31,46,0.38)_58%,rgba(11,31,46,0.68))]"></div>
      <div class="relative border-b border-white/20 px-6 pb-6 pt-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="eyebrow">Signal observatory</p>
            <h2 class="mt-3 text-2xl">Inspectable governance with symbolic depth.</h2>
          </div>
          <div class="rounded-full border border-white/35 bg-white/15 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-slate-100">
            Live
          </div>
        </div>
      </div>

      <div class="relative px-6 py-7">
        <div class="overflow-hidden rounded-[1.7rem] border border-white/30 bg-[linear-gradient(180deg,rgba(255,255,255,0.1),rgba(255,255,255,0.03))] p-4 backdrop-blur-md">
          <div class="relative overflow-hidden rounded-[1.35rem] border border-white/28 bg-[linear-gradient(180deg,rgba(173,206,255,0.18),rgba(84,111,152,0.16)_54%,rgba(8,16,28,0.54)_100%)] px-5 py-6">
            <div class="absolute left-0 right-0 top-[56%] h-px bg-gradient-to-r from-transparent via-white/60 to-transparent"></div>
            <div class="absolute left-[14%] right-[14%] top-5 h-px bg-gradient-to-r from-transparent via-white/45 to-transparent"></div>
            <div class="absolute right-5 top-5 rounded-full border border-white/35 bg-white/12 px-2 py-1 text-[0.62rem] font-medium uppercase tracking-[0.22em] text-slate-100">
              Horizon
            </div>
            <div class="mx-auto mt-6 flex h-44 w-44 items-center justify-center rounded-full border border-white/28 bg-[radial-gradient(circle,rgba(255,255,255,0.2),transparent_64%)]">
              <div class="relative flex h-32 w-32 items-center justify-center rounded-full border border-[rgba(61,214,200,0.55)] shadow-[0_0_36px_rgba(61,214,200,0.22)]">
                <div class="absolute inset-[14%] rounded-full border border-[rgba(255,255,255,0.3)]"></div>
                <div class="absolute inset-[30%] rounded-full border border-[rgba(201,168,76,0.55)]"></div>
                <div class="absolute bottom-[22%] left-1/2 h-[42%] w-[22%] -translate-x-1/2 rounded-t-[999px] border border-[rgba(61,214,200,0.75)] bg-[linear-gradient(180deg,rgba(255,255,255,0.2),rgba(201,168,76,0.18))]"></div>
                <div class="absolute bottom-[52%] left-1/2 h-px w-[52%] -translate-x-1/2 bg-gradient-to-r from-transparent via-white/75 to-transparent"></div>
                <div class="absolute left-1/2 top-[18%] h-[22%] w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-white/80 to-transparent"></div>
              </div>
            </div>
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              <div class="rounded-[1.1rem] border border-white/28 bg-white/8 p-3 backdrop-blur-sm">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-aqua/90">Primary focus</p>
                <p class="mt-2 text-sm leading-6 text-slate-100">
                  AI governance design, traceability, documentation, and risk mapping for organizations that need
                  clarity before scale.
                </p>
              </div>
              <div class="rounded-[1.1rem] border border-white/28 bg-white/8 p-3 backdrop-blur-sm">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-aqua/90">Parallel practice</p>
                <p class="mt-2 text-sm leading-6 text-slate-100">
                  Writing and scholarship on legitimacy, digital enchantment, queer methods, postfeminist media, and
                  institutional reading.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.2rem] border border-white/28 bg-white/8 px-4 py-4 backdrop-blur-sm">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-aqua/90">Base</p>
            <p class="mt-2 text-sm text-slate-100">{siteMeta.location}</p>
          </div>
          <div class="rounded-[1.2rem] border border-white/28 bg-white/8 px-4 py-4 backdrop-blur-sm">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-aqua/90">Outputs</p>
            <p class="mt-2 text-sm text-slate-100">Publications, dossiers, prototypes, and manuscripts</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>
