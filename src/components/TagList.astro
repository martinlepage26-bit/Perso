---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="flex flex-wrap gap-2" aria-label="Tags">
  {tags.map((tag) => (
    <li class="rounded-full border border-white/10 bg-[rgba(255,255,255,0.05)] px-3 py-1 text-xs font-medium uppercase tracking-[0.1em] text-slate-300">
      {tag}
    </li>
  ))}
</ul>
