---
import { navigation, siteMeta } from '../data/site';
---

<footer class="border-t border-[rgba(201,168,76,0.16)] bg-[linear-gradient(180deg,rgba(11,31,46,0.72),rgba(15,59,62,0.92))]">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,1fr)_420px]">
    <div class="space-y-5">
      <p class="eyebrow">Martin Lepage</p>
      <h2 class="max-w-xl text-3xl md:text-4xl">
        Governance, scholarship, and authorship that stays legible under pressure.
      </h2>
      <p class="max-w-2xl text-base text-slate-200">
        Built in Astro with content collections so updates mostly live in markdown and simple data files. Replace
        placeholders, update the public links, and the site stays structurally clean.
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="button-primary" href="/contact/">Get in touch</a>
        <a class="button-secondary" href="/rss.xml">RSS feed</a>
      </div>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <div>
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-accent">Navigate</h3>
        <ul class="mt-4 space-y-3">
          {navigation.map(({ href, label }) => (
            <li>
              <a class="text-sm text-slate-200 hover:text-aqua" href={href}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-accent">Elsewhere</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a class="text-slate-200 hover:text-aqua" href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a></li>
          <li><a class="text-slate-200 hover:text-aqua" href={siteMeta.linkedIn}>LinkedIn</a></li>
          <li><a class="text-slate-200 hover:text-aqua" href={siteMeta.github}>GitHub</a></li>
          <li><a class="text-slate-200 hover:text-aqua" href={siteMeta.orcid}>ORCID</a></li>
          <li><a class="text-slate-200 hover:text-aqua" href={siteMeta.substack}>Substack</a></li>
          <li><a class="text-slate-200 hover:text-aqua" href={siteMeta.instagram}>Instagram</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="shell flex flex-col gap-3 border-t border-[rgba(201,168,76,0.14)] py-5 text-sm text-slate-300 md:flex-row md:items-center md:justify-between">
    <p>&copy; {new Date().getFullYear()} Martin Lepage. Montreal-based scholar, writer, and AI governance consultant.</p>
    <p>Editorial atmosphere, restrained motion, and content-first architecture.</p>
  </div>
</footer>
