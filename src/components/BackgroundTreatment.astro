---
interface Props {
  variant?: 'hero' | 'section' | 'panel';
  className?: string;
}

const { variant = 'section', className = '' } = Astro.props;
const showEye = variant === 'hero';
---

<div aria-hidden="true" class:list={['pointer-events-none absolute inset-0 overflow-hidden', className]}>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-4%,rgba(61,214,200,0.16),transparent_28%),radial-gradient(circle_at_84%_18%,rgba(201,168,76,0.14),transparent_22%),linear-gradient(180deg,rgba(11,31,46,0.54),rgba(11,31,46,0.12)_58%,transparent)]"></div>
  <div class="absolute left-1/2 top-[-22%] h-[138%] w-[66%] -translate-x-1/2 rounded-[999px] border border-white/20"></div>
  <div class="absolute left-1/2 top-[-17%] h-[128%] w-[57%] -translate-x-1/2 rounded-[999px] bg-[linear-gradient(180deg,rgba(61,214,200,0.08),rgba(201,168,76,0.02))] blur-3xl"></div>
  <div class="absolute bottom-[-6%] left-1/2 h-44 w-[74%] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(201,168,76,0.18),rgba(61,214,200,0.06),transparent_72%)] blur-3xl"></div>
  <div class="absolute left-[10%] right-[10%] top-[28%] h-px bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>
  <div class="absolute left-[16%] right-[16%] top-[54%] h-px bg-gradient-to-r from-transparent via-[rgba(157,194,255,0.44)] to-transparent"></div>
  <div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-accent/30 to-transparent"></div>
  <img
    src="/assets/isometric-grid-corner.png"
    alt=""
    class="absolute right-0 top-0 hidden w-72 opacity-[0.14] mix-blend-screen lg:block"
  />
  <img
    src="/assets/geometric-motif-bottomleft.png"
    alt=""
    class="absolute bottom-0 left-0 hidden w-72 opacity-[0.16] mix-blend-screen lg:block"
  />
  {
    showEye && (
      <div class="absolute right-[-4%] top-8 hidden h-[22rem] w-[22rem] rounded-full border border-white/18 bg-[radial-gradient(circle,rgba(201,168,76,0.1),rgba(61,214,200,0.03),transparent_68%)] blur-[1px] xl:block">
        <div class="absolute inset-[18%] rounded-full border border-[rgba(61,214,200,0.22)]"></div>
        <div class="absolute inset-[32%] rounded-full border border-[rgba(201,168,76,0.24)]"></div>
        <div class="absolute left-1/2 top-[18%] h-[64%] w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-white/40 to-transparent"></div>
        <div class="absolute left-[18%] right-[18%] top-1/2 h-px -translate-y-1/2 bg-gradient-to-r from-transparent via-white/28 to-transparent"></div>
      </div>
    )
  }
</div>
