---
import { getCollection } from 'astro:content';
import SectionIntro from '../../components/SectionIntro.astro';
import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, sortByDate } from '../../lib/content';

const talks = sortByDate(await getCollection('talks'));
const tags = collectTags(talks);
---

<BaseLayout title="Talks and Media" description="Conference presentations, sessions, and public-facing talks by Martin Lepage.">
  <section class="section-shell">
    <SectionIntro
      eyebrow="Talks and media"
      title="Selected presentations, sessions, and public-facing appearances."
      description="This route is intentionally compact: enough to demonstrate speaking and convening history, without pretending the site is a speaker bureau."
    />

    <div class="mt-10 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-slate-200">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-10 space-y-5">
      {talks.map((talk) => (
        <article class="veil-panel grid gap-5 md:grid-cols-[160px_minmax(0,1fr)]">
          <div>
            <p class="eyebrow">{talk.data.dateLabel ?? talk.data.date.getFullYear()}</p>
            <p class="mt-3 text-sm uppercase tracking-[0.2em] text-slate-400">{talk.data.format}</p>
          </div>
          <div>
            <h2 class="text-3xl">{talk.data.title}</h2>
            <p class="mt-2 text-sm uppercase tracking-[0.2em] text-slate-400">
              {talk.data.event} · {talk.data.location}
            </p>
            <p class="mt-4 text-base text-slate-200">{talk.data.description}</p>
            <div class="mt-4">
              <TagList tags={talk.data.tags} />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
