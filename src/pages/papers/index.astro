---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, sortByYear } from '../../lib/content';
import { researchOverview, researchProfile } from '../../data/research';
import { siteMeta } from '../../data/site';

const papers = sortByYear(await getCollection('papers'));
const tags = collectTags(papers);
---

<BaseLayout
  title="Papers and Publications"
  description="Academic papers, articles, chapters, manuscripts, and publication-stage research projects by Martin Lepage."
>
  <section class="section-shell">
    <SectionIntro
      eyebrow="Papers and publications"
      title="Research across ritual, media, gender, and governance."
      description="Peer-reviewed work, chapters, reviews, and in-progress manuscripts, with status stated plainly."
    />

    <div class="mt-8 max-w-4xl">
      <p class="text-lg leading-8 text-slate-200">{researchProfile}</p>
    </div>

    <ul class="bullet-links mt-6">
      <li><a class="link-inline" href={siteMeta.academia}>Academia.edu papers and profile</a></li>
    </ul>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {researchOverview.map((item) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">Research overview</p>
          <h2 class="mt-3 text-[1.45rem] md:text-[1.62rem]">{item.title}</h2>
          <p class="mt-4 text-base text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-10">
      <FilterBar scopeId="papers" tags={tags} searchPlaceholder="Search papers" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="papers">
      {papers.map((paper) => <PublicationCard paper={paper} />)}
    </div>
  </section>
</BaseLayout>
