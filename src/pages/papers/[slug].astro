---
import { getCollection, render } from 'astro:content';
import EntryHero from '../../components/EntryHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug } from '../../lib/content';
import { buildArticleSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({
    params: { slug: contentSlug(paper.id) },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);
const canonical = `/papers/${contentSlug(paper.id)}/`;
const structuredData = buildArticleSchema({
  title: paper.data.title,
  description: paper.data.abstract,
  url: new URL(canonical, 'https://martinlepage.example').toString(),
  datePublished: `${paper.data.year}-01-01`,
});
---

<BaseLayout title={paper.data.title} description={paper.data.abstract} canonical={canonical} structuredData={structuredData}>
  <EntryHero
    eyebrow={paper.data.type}
    title={paper.data.title}
    description={paper.data.abstract}
    meta={`${paper.data.year} · ${paper.data.venue} · ${paper.data.status}`}
    backHref="/papers/"
    backLabel="Back to publications"
    tags={paper.data.tags}
    links={paper.data.links}
  />

  <article class="section-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div class="reading-flow">
      <Content />
    </div>

    <aside class="space-y-6">
      <section class="veil-panel">
        <p class="eyebrow">Citation</p>
        <p class="mt-4 text-base text-slate-200">{paper.data.citation}</p>
      </section>
      <section class="veil-panel">
        <p class="eyebrow">Status</p>
        <p class="mt-4 text-base text-slate-200">{paper.data.status}</p>
      </section>
      {paper.data.links.length > 0 && (
        <section class="veil-panel">
          <p class="eyebrow">Links</p>
          <ul class="mt-4 space-y-3">
            {paper.data.links.map((link) => (
              <li><a class="link-inline" href={link.url}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
