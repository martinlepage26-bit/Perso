---
import '@fontsource-variable/space-grotesk';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/600.css';
import '../../styles/astral-standalone.css';
import AstralGaialogyApp from '../../components/astral/AstralGaialogyApp.astro';
import { gaialogySigns } from '../../data/astralYear';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="ASTRAL standalone: cosmic and earth-rooted seasonal readings from Breath of the Astral Year."
    />
    <meta name="theme-color" content="#0e1532" />
    <title>ASTRAL | Cosmic + Roots</title>
  </head>
  <body class="astral-standalone">
    <div class="astral-shell">
      <header class="astral-header">
        <a class="astral-brand" href="/astral/">
          <span class="astral-mark">ASTRAL</span>
          <span class="astral-tagline">Cosmic + Roots</span>
        </a>
        <nav class="astral-nav" aria-label="ASTRAL navigation">
          <a href="/astral-year/">Book</a>
          <a href="/astral-year/glossary/">Glossary</a>
          <a href="/projects/astral/">Project</a>
        </nav>
      </header>

      <main class="astral-main">
        <section class="astral-hero">
          <p class="astral-eyebrow">Gaialogy app</p>
          <h1>Cosmic sky. Rooted life.</h1>
          <p>Seasonal readings that stay human, grounded, and alive.</p>
          <div class="astral-actions">
            <a class="astral-button primary" href="#astral-tool">Open reading tool</a>
            <a class="astral-button secondary" href="/astral-year/glossary/">Sign glossary</a>
          </div>
        </section>

        <section id="astral-tool" class="astral-tool">
          <AstralGaialogyApp signs={gaialogySigns} />
        </section>
      </main>
    </div>
  </body>
</html>
