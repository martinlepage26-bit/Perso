---
import ContactBlock from '../components/ContactBlock.astro';
import SectionIntro from '../components/SectionIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Martin Lepage for AI governance strategy, research collaborations, editorial inquiries, talks, and media opportunities."
>
  <section class="section-shell">
    <SectionIntro
      eyebrow="Contact"
      title="Simple ways to get in touch."
      description="Governance, research, editorial, and speaking inquiries all route here."
    />

    <div class="mt-12">
      <ContactBlock />
    </div>
  </section>
</BaseLayout>
