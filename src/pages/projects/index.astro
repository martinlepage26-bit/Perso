---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, sortByYear } from '../../lib/content';

const projects = sortByYear(await getCollection('projects'));
const tags = collectTags(projects);
---

<BaseLayout
  title="Projects"
  description="Academic, advisory, and creative projects by Martin Lepage, including self-published books, governance frameworks, and digital work."
>
  <section class="section-shell">
    <SectionIntro
      eyebrow="Projects"
      title="Projects with status stated plainly."
      description="Self-published books, governance frameworks, long-form work, and digital experiments in one index."
    />

    <div class="mt-10">
      <FilterBar scopeId="projects" tags={tags} searchPlaceholder="Search projects" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="projects">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
