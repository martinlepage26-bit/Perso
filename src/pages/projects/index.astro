---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, sortByYear } from '../../lib/content';

const projects = sortByYear(await getCollection('projects'));
const tags = collectTags(projects);
---

<BaseLayout
  title="Projects"
  description="Governance work, books, and digital projects by Martin Lepage."
>
  <section class="section-shell">
    <SectionIntro
      eyebrow="Projects"
      title="Projects, with status kept clear."
      description="Governance work, books, long-form writing, and digital experiments in one place."
    />

    <div class="mt-10">
      <FilterBar scopeId="projects" tags={tags} searchPlaceholder="Search projects" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="projects">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
