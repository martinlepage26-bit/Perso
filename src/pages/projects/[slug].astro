---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { getCollection, render } from 'astro:content';
import EntryHero from '../../components/EntryHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: contentSlug(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const canonical = `/projects/${contentSlug(project.id)}/`;
const publicDir = fileURLToPath(new URL('../../../public/', import.meta.url));
const projectImagePath = join(publicDir, project.data.image.replace(/^\/+/, ''));
const hasProjectImage = existsSync(projectImagePath);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={hasProjectImage ? project.data.image : undefined}
  canonical={canonical}
>
  <EntryHero
    eyebrow="Project"
    title={project.data.title}
    description={project.data.description}
    meta={`${project.data.year} · ${project.data.status} · ${project.data.role}`}
    backHref="/projects/"
    backLabel="Back to projects"
    tags={project.data.tags}
    links={project.data.links}
  />

  <article class="section-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div class="reading-flow">
      {
        hasProjectImage ? (
          <figure class="mb-8 overflow-hidden rounded-[1.8rem] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(95,105,156,0.22),transparent_30%),linear-gradient(180deg,rgba(20,29,45,0.48),rgba(8,14,24,0.62))]">
            <div class="aspect-[16/9] overflow-hidden border-b border-white/10">
              <img class="h-full w-full object-cover" src={project.data.image} alt={project.data.imageAlt} loading="eager" />
            </div>
            <figcaption class="space-y-4 p-6 md:p-8">
              <p class="eyebrow">{project.data.status}</p>
              <h2 class="text-3xl">{project.data.subtitle}</h2>
              <p class="text-base text-slate-200">{project.data.imageAlt}</p>
            </figcaption>
          </figure>
        ) : (
          <div class="mb-8 overflow-hidden rounded-[1.8rem] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(95,105,156,0.22),transparent_30%),linear-gradient(180deg,rgba(20,29,45,0.48),rgba(8,14,24,0.62))] p-5">
            <div class="rounded-[1.4rem] border border-white/12 bg-white/6 p-8">
              <p class="eyebrow">{project.data.status}</p>
              <h2 class="mt-3 text-3xl">{project.data.subtitle}</h2>
              <p class="mt-4 text-base text-slate-200">{project.data.imageAlt}</p>
            </div>
          </div>
        )
      }
      <Content />
    </div>

    <aside class="space-y-6">
      <section class="veil-panel">
        <p class="eyebrow">Role</p>
        <p class="mt-4 text-base text-slate-200">{project.data.role}</p>
      </section>
      <section class="veil-panel">
        <p class="eyebrow">Outputs</p>
        <ul class="mt-4 ml-5 list-disc space-y-2 text-base text-slate-200">
          {project.data.outputs.map((output) => (
            <li>{output}</li>
          ))}
        </ul>
      </section>
      {project.data.links.length > 0 && (
        <section class="veil-panel">
          <p class="eyebrow">Links</p>
          <ul class="mt-4 space-y-3">
            {project.data.links.map((link) => (
              <li><a class="link-inline" href={link.url}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
