---
import { getCollection } from 'astro:content';
import ContactBlock from '../components/ContactBlock.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionIntro from '../components/SectionIntro.astro';
import WritingCard from '../components/WritingCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { estimateReadingMinutes, sortByDate, sortByYear } from '../lib/content';
import { biography, homeHighlights, siteMeta } from '../data/site';

const papers = sortByYear(await getCollection('papers'));
const projects = sortByYear(await getCollection('projects'));
const writings = sortByDate(await getCollection('writings', ({ data }) => !data.draft));
const talks = sortByDate(await getCollection('talks'));

const featuredPapers = papers.filter((entry) => entry.data.featured).slice(0, 3);
const featuredProjects = projects.filter((entry) => entry.data.featured).slice(0, 3);
const featuredWriting = writings.filter((entry) => entry.data.featured).slice(0, 3);
const featuredTalks = talks.filter((entry) => entry.data.featured).slice(0, 3);
const symbolicProjectOrder = [
  'the-violet-gem',
  'socialcompass-agatha',
  'from-ai-anxiety-to-recursive-governance-under-constraint',
  'the-sealed-card-protocol',
];
const symbolicProjects = symbolicProjectOrder
  .map((slug) => projects.find((entry) => entry.id.replace(/\.md$/i, '') === slug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));
---

<BaseLayout description={siteMeta.description}>
  <Hero />

  <section class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]">
      <SectionIntro
        eyebrow="Overview"
        title="A public site with operational clarity."
        description={biography.intro}
      />

      <div class="veil-panel space-y-6">
        <p class="text-lg leading-8 text-slate-200">
          Martin’s practice links governance, research, and authorship through one recurring question: how do systems
          authorize power, and how do people live inside them once they become real?
        </p>
        <p class="text-base text-slate-200">
          That question appears here in AI governance work, ritual and media analysis, book projects, and long-form
          essays.
        </p>
        <a class="link-inline" href="/about/">Read the fuller biography</a>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {homeHighlights.map((item) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">Focus</p>
          <h3 class="mt-3 text-[1.45rem] md:text-[1.62rem]">{item.title}</h3>
          <p class="mt-4 text-base text-slate-200">{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell border-y border-white/8 bg-white/4">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Featured publications"
        title="Research across ritual, gender, media, and governance."
        description="Academic work with publication status kept visible and plain."
      />
    </div>

    <div class="mt-3">
      <a class="link-inline" href="/papers/">Browse all publications</a>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {featuredPapers.map((paper) => <PublicationCard paper={paper} />)}
    </div>
  </section>

  <section class="section-shell">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Projects"
        title="Projects across books, governance, and digital work."
        description="A mixed project archive that keeps statuses and formats distinct."
      />
    </div>

    <div class="mt-3">
      <a class="link-inline" href="/projects/">Browse all projects</a>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section-shell border-y border-white/8 bg-white/3">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Current teasers"
        title="Current teaser projects."
        description="Four developing works now appear as public-facing previews."
      />
    </div>

    <div class="mt-3">
      <a class="link-inline" href="/projects/">Open the full project index</a>
    </div>

    <div class="mt-12 grid gap-6 xl:grid-cols-4 md:grid-cols-2">
      {symbolicProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section-shell border-y border-white/8 bg-white/4">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Writing"
        title="Essays and public criticism."
        description="A writing archive that keeps theory, atmosphere, and argument close together."
      />
    </div>

    <div class="mt-3">
      <a class="link-inline" href="/writing/">Read the writing archive</a>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        featuredWriting.map((writing) => (
          <WritingCard writing={writing} readingMinutes={estimateReadingMinutes(writing.body ?? '')} />
        ))
      }
    </div>
  </section>

  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div class="veil-panel">
        <p class="eyebrow">Talks and media</p>
        <h2 class="mt-3 text-[1.68rem] md:text-[1.9rem]">Conference sessions, research presentations, and public-facing appearances.</h2>
        <div class="mt-8 space-y-4">
          {featuredTalks.map((talk) => (
            <article class="rounded-[1.4rem] border border-white/10 bg-white/6 p-5">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-aqua">
                {talk.data.dateLabel ?? talk.data.date.getFullYear()}
              </p>
              <h3 class="mt-2 text-[1.28rem] md:text-[1.45rem]">{talk.data.title}</h3>
              <p class="mt-2 text-sm uppercase tracking-[0.2em] text-slate-400">
                {talk.data.event} · {talk.data.format}
              </p>
              <p class="mt-3 text-base text-slate-200">{talk.data.description}</p>
            </article>
          ))}
        </div>
        <div class="mt-6"><a class="link-inline" href="/talks/">View all talks</a></div>
      </div>

      <div class="veil-panel">
        <p class="eyebrow">Resume and CV</p>
        <h2 class="mt-3 text-[1.68rem] md:text-[1.9rem]">Downloadable, readable, and aligned with the public profile.</h2>
        <p class="mt-4 text-base text-slate-200">
          The resume route gathers governance, research operations, teaching, archival work, and recent clinical
          coordination into one compact document.
        </p>
        <ul class="bullet-links mt-6">
          <li><a class="link-inline" href="/resume/">Open resume</a></li>
          <li><a class="link-inline" href="/files/Martin-Lepage-CV-2026.pdf">Download PDF</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell pt-0">
    <ContactBlock compact />
  </section>
</BaseLayout>
