---
import BackgroundTreatment from '../components/BackgroundTreatment.astro';
import ContactBlock from '../components/ContactBlock.astro';
import SectionIntro from '../components/SectionIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { biography, researchInterests, timeline } from '../data/site';
---

<BaseLayout title="About" description={biography.intro}>
  <section class="relative overflow-hidden border-b border-white/10">
    <BackgroundTreatment variant="hero" />
    <div class="section-shell relative grid gap-10 lg:grid-cols-[minmax(0,1fr)_380px] lg:items-center">
      <div>
        <SectionIntro
          eyebrow="About"
          title="Scholar, writer, and governance strategist."
          description={biography.intro}
        />
        <div class="mt-8 space-y-5">
          {biography.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <figure class="veil-panel relative overflow-hidden p-3">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(171,140,255,0.18),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.04),transparent_48%)]"></div>
        <div class="relative overflow-hidden rounded-[1.6rem] border border-white/12 bg-[linear-gradient(180deg,rgba(17,30,48,0.4),rgba(8,16,28,0.16))]">
          <img
            src="/assets/portrait.png"
            alt="Portrait of Martin Lepage"
            class="h-full min-h-[30rem] w-full object-cover object-center"
          />
          <div class="absolute inset-x-0 bottom-0 bg-[linear-gradient(180deg,transparent,rgba(5,12,23,0.78))] p-6">
            <p class="eyebrow">Martin Lepage</p>
            <p class="mt-2 max-w-xs text-sm leading-6 text-slate-100">
              Working across ritual studies, media analysis, public writing, and legitimacy-focused systems thinking.
            </p>
          </div>
        </div>
      </figure>
    </div>
  </section>

  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div class="veil-panel">
        <p class="eyebrow">Current work</p>
        <h2 class="mt-3 text-[1.68rem] md:text-[1.9rem]">A practice built around legitimacy and decision visibility.</h2>
        <p class="mt-5 text-lg leading-8 text-slate-200">{biography.currentWork}</p>
      </div>

      <div class="veil-panel">
        <p class="eyebrow">Research and professional interests</p>
        <ul class="mt-5 space-y-3 text-base text-slate-200">
          {researchInterests.map((interest) => (
            <li class="rounded-[1rem] border border-white/10 bg-[rgba(255,255,255,0.05)] px-4 py-3">
              {interest}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-white/10 bg-[rgba(255,255,255,0.03)]">
    <SectionIntro
      eyebrow="Timeline"
      title="Path to the current practice."
      description="A route shaped by long-form analysis and documentation-heavy work."
    />

    <div class="mt-12 space-y-5">
      {timeline.map((item) => (
        <article class="grid gap-4 rounded-[1.5rem] border border-white/10 bg-[rgba(17,30,48,0.72)] p-6 backdrop-blur-lg md:grid-cols-[140px_minmax(0,1fr)]">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-aqua">{item.year}</p>
          <div>
            <h3 class="text-[1.28rem] md:text-[1.45rem]">{item.title}</h3>
            <p class="mt-2 text-base text-slate-200">{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell">
    <ContactBlock />
  </section>
</BaseLayout>
