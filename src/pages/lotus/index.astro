---
import LotusBloomJourney from '../../components/lotus/LotusBloomJourney.astro';
import LotusLayout from '../../layouts/LotusLayout.astro';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'Lotus is a sequential bloom journaling experience: one question, one active writing surface, and one upward movement at a time.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lotus',
  description: pageDescription,
  applicationCategory: 'LifestyleApplication',
  url: buildCanonical('/lotus/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
};
---

<LotusLayout title="Lotus" description={pageDescription} canonical="/lotus/" structuredData={structuredData}>
  <LotusBloomJourney />
</LotusLayout>
