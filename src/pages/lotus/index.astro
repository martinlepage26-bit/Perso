---
import LotusWorkbench from '../../components/lotus/LotusWorkbench.astro';
import LotusVectorWorkbench from '../../components/lotus/LotusVectorWorkbench.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { lotusBoundaryCards, lotusSignalGroups } from '../../data/lotus';
import LotusLayout from '../../layouts/LotusLayout.astro';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'LOTUS is a reflective support and agency-scoring system that helps people make sense of stress, instability, isolation, blocked options, and social invisibility.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lotus',
  description: pageDescription,
  applicationCategory: 'ResearchApplication',
  url: buildCanonical('/lotus/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
};
---

<LotusLayout title="Lotus" description={pageDescription} canonical="/lotus/" structuredData={structuredData}>
  <section class="section-shell border-b border-[rgba(255,255,255,0.08)]">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.16fr)_minmax(280px,0.84fr)] xl:items-start">
      <div class="max-w-4xl">
        <p class="eyebrow">Lotus</p>
        <h1 class="mt-5">Agency scorer and reflective workbench.</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
          Score a note in the browser, inspect the active signal groups, and move straight into the full LOTUS vector
          model with all the categories and narrative questions below. This page is the app, not a landing page for it.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href="#lotus-workbench">Start scoring</a>
          <a class="button-secondary" href="#lotus-vector">Jump to the questions</a>
          <a class="button-secondary" href="/projects/bonded-intelligence-under-constraint/">Read the framework paper</a>
          <a class="button-secondary" href="/projects/lotus/">Open the project record</a>
        </div>
      </div>

      <aside class="veil-panel lotus-orientation-card">
        <p class="eyebrow">Orientation</p>
        <div class="mt-5 space-y-4">
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">Browser-first</p>
            <p class="lotus-orientation-copy">Paste a note, score it, and inspect the active signals without leaving the page.</p>
          </div>
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">Questions intact</p>
            <p class="lotus-orientation-copy">The full narrative guide and vector categories remain on this same route below the scorer.</p>
          </div>
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">Boundary</p>
            <p class="lotus-orientation-copy">LOTUS is not diagnosis or crisis care. It is a bounded reflective and analytical tool.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="lotus-workbench" class="section-shell">
    <SectionIntro
      eyebrow="Workbench"
      title="Map the pressure points in your own words."
      description="Paste text — a journal entry, a situation description, a note — and LOTUS identifies which signal groups are present. No text is uploaded or stored. The reading stays in your browser."
    />

    <div class="mt-12">
      <LotusWorkbench />
    </div>
  </section>

  <section id="lotus-vector" class="section-shell border-y border-[rgba(255,255,255,0.08)] bg-[rgba(8,11,16,0.72)]">
    <SectionIntro
      eyebrow="Vector model"
      title="Rate the pressures and supports. See where agency stands."
      description="This tool is designed for researchers, clinicians, and practitioners. Rate each dimension of a person's situation — base state, constraints, and scaffolds — and LOTUS computes the effective agency vector using the full formula chain."
    />
    <div class="mt-12">
      <LotusVectorWorkbench />
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(255,255,255,0.08)] bg-[rgba(8,11,16,0.72)]">
    <SectionIntro
      eyebrow="Signal library"
      title="Six patterns LOTUS looks for."
      description="LOTUS reads text for signals across six dimensions of a person's situation. Each group names a different kind of pressure, condition, or capacity — from how choices are made under stress to how meaning and identity hold under load."
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {lotusSignalGroups.map((group) => (
        <article class="veil-panel h-full">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="eyebrow">{group.label}</p>
              <h2 class="mt-4 text-[1.08rem] md:text-[1.18rem]">{group.description}</h2>
            </div>
            <span class="lotus-weight-badge">{group.weight}</span>
          </div>
          <p class="mt-5 text-sm uppercase tracking-[0.18em] text-slate-400">Representative terms</p>
          <p class="mt-3 text-base leading-7 text-slate-200">{group.terms.slice(0, 5).join(', ')}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="lotus-boundary" class="section-shell">
    <SectionIntro
      eyebrow="What LOTUS does not claim"
      title="LOTUS maps what it can. It does not define who you are."
      description="Clarity can be a form of support. But interpretation must remain revisable. LOTUS is designed to open understanding, not close it down — and to hold both the human and the structural dimensions without collapsing either."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {lotusBoundaryCards.map((item) => (
        <article class="veil-panel h-full">
          <h2 class="text-[1.08rem] md:text-[1.18rem]">{item.title}</h2>
          <p class="mt-4 text-base leading-7 text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <style>
    .lotus-orientation-card {
      height: fit-content;
    }

    .lotus-orientation-item + .lotus-orientation-item {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 1rem;
    }

    .lotus-orientation-label {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #cc9967;
    }

    .lotus-orientation-label::before {
      content: '';
      width: 0.55rem;
      height: 0.55rem;
      border-radius: 999px;
      border: 1px solid rgba(204, 153, 103, 0.42);
      background: rgba(204, 153, 103, 0.12);
    }

    .lotus-orientation-copy {
      margin-top: 0.55rem;
      color: rgb(226 232 240 / 0.92);
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .lotus-weight-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2.3rem;
      height: 2.3rem;
      border-radius: 999px;
      background: rgba(189, 138, 81, 0.12);
      color: var(--color-heading);
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-weight: 700;
      background: rgba(204, 153, 103, 0.14);
      color: var(--color-moon);
    }
  </style>
</LotusLayout>
