---
import { getCollection } from 'astro:content';
import ResumeSection from '../components/ResumeSection.astro';
import SectionIntro from '../components/SectionIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isPublishedPaper, sortByYear } from '../lib/content';

const papers = sortByYear(await getCollection('papers'));
const selectedPublications = papers.filter((entry) => isPublishedPaper(entry)).slice(0, 4);
---

<BaseLayout
  title="Resume and CV"
  description="On-page resume and downloadable CV for Martin Lepage, covering governance work, research operations, publications, and professional experience."
>
  <section class="section-shell">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Resume and CV"
        title="Read online or download."
        description="A short public CV with experience, publications, and training."
      />

      <ul class="bullet-links">
        <li><a class="link-inline" href="/files/Martin-Lepage-CV-2026.pdf">Download PDF</a></li>
        <li><a class="link-inline" href="/files/Martin-Lepage-CV-2026.docx">Download DOCX</a></li>
      </ul>
    </div>

    <div class="mt-12">
      <ResumeSection selectedPublications={selectedPublications} />
    </div>
  </section>
</BaseLayout>
