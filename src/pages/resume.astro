---
import { getCollection } from 'astro:content';
import ResumeSection from '../components/ResumeSection.astro';
import SectionIntro from '../components/SectionIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortByYear } from '../lib/content';

const papers = sortByYear(await getCollection('papers'));
const selectedPublications = papers.filter((entry) => entry.data.featured).slice(0, 4);
---

<BaseLayout
  title="Resume and CV"
  description="On-page resume and downloadable CV for Martin Lepage, covering AI governance, research operations, publications, and professional experience."
>
  <section class="section-shell">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Resume and CV"
        title="Readable on the page, downloadable when someone needs the file."
        description="This route is shaped for consulting, media, and academic opportunities alike: enough detail to establish credibility, but structured so the editing workflow stays simple."
      />

      <div class="flex flex-wrap gap-3">
        <a class="button-primary" href="/files/Martin-Lepage-CV-2026.pdf">Download PDF</a>
        <a class="button-secondary" href="/files/Martin-Lepage-CV-2026.docx">Download DOCX</a>
      </div>
    </div>

    <div class="mt-12">
      <ResumeSection selectedPublications={selectedPublications} />
    </div>
  </section>
</BaseLayout>
